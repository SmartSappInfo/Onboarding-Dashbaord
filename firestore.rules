rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Admin Rules ---
    // Allow authenticated users full read/write access to these collections.
    // This is for the admin dashboard functionality.
    match /schools/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /meetings/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /media/{document=**} {
      allow read, write: if request.auth != null;
    }

    // --- Public Rules ---
    // Allow public GET access for specific pages (e.g., meeting pages).
    // This is OR-ed with the admin rules above, so admins can also get.
    match /schools/{schoolId} {
      allow get: if true;
    }
    match /meetings/{meetingId} {
      allow get: if true;
    }
    
    // --- Survey Rules ---
    match /surveys/{surveyId} {
      // Admins can create, update, delete surveys
      allow write: if request.auth != null;
      // Anyone can read a published survey, admins can read any survey
      allow get: if resource.data.status == 'published' || request.auth != null;
      // Admins can list all surveys
      allow list: if request.auth != null;
    }

    match /surveys/{surveyId}/responses/{responseId} {
      // Anyone can create a response for a published survey
      allow create: if get(/databases/$(database)/documents/surveys/$(surveyId)).data.status == 'published';
      // Admins can read and list responses
      allow read, list: if request.auth != null;
    }
  }
}
