
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      // Check if the user is an admin by looking at their profile.
      // This is now safer and checks for the document's existence first.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && userDoc.data.isAuthorized == true;
    }

    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- Admin-Only Collections ---
    // Allow authenticated admins full read/write access to these collections.
    match /onboardingStages/{document=**} {
      allow read, write: if isAuthorized();
    }
    match /media/{document=**} {
        allow read, write: if isAuthorized();
    }
     match /modules/{document=**} {
      allow read, write: if isAuthorized();
    }

    // --- School Rules ---
    match /schools/{schoolId} {
      // Admins can perform any action on schools
      allow write: if isAuthorized();
      // Public can read a single school for meeting pages, admins can list all schools
      allow get: if true;
      allow list: if isAuthorized();
    }
    
    // --- Meeting Rules ---
    match /meetings/{meetingId} {
        // Admins can create, update, and delete any meeting
        allow write: if isAuthorized();
        // Admins can list all meetings
        allow list: if isAuthorized();
        // Anyone can view a specific meeting page
        allow get: if true;
    }
    
    // --- User-Specific Rules ---
    // Allow users to manage their own dashboard layout
    match /dashboardLayouts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // --- User Management Rules ---
    match /users/{userId} {
      // Admins can read/write any user profile to authorize them.
      allow list, write: if isAuthorized();
      // Users can create their own profile on signup.
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can read their own profile, and admins can read any profile.
      allow get: if (isSignedIn() && request.auth.uid == userId) || isAuthorized();
    }
    
    // --- Survey Rules ---
    match /surveys/{surveyId} {
      // Admins can create, update, delete surveys.
      allow write: if isAuthorized();
      // Anyone can read a published survey, and admins can read any survey.
      allow get: if resource.data.status == 'published' || isAuthorized();
      // Admins can list all surveys.
      allow list: if isAuthorized();
    }

    match /surveys/{surveyId}/responses/{responseId} {
      // Anyone can create a response for a published survey.
      allow create: if get(/databases/$(database)/documents/surveys/$(surveyId)).data.status == 'published';
      // Admins can read and list all responses.
      allow read, list: if isAuthorized();
    }

    match /surveys/{surveyId}/summaries/{summaryId} {
      // Admins can create, read, list, and delete all summaries for a survey.
      allow create, read, list, delete: if isAuthorized();
    }

    // --- Activity Log Rules ---
    // The activity log is the immutable source of truth for all actions.
    match /activities/{activityId} {
      // Only authorized backend processes (via server-side logic) can create activities.
      // This ensures that `userId` and `timestamp` are trustworthy.
      allow create: if isAuthorized();
      
      // Only authorized users can read the activity feed.
      allow read, list: if isAuthorized();
      
      // CRITICAL: Activities are immutable. They cannot be updated or deleted by anyone
      // through the client SDKs, ensuring a permanent and tamper-proof audit trail.
      allow update, delete: if false;
    }
  }
}
