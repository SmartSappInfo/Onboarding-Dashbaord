rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && userDoc.data.isAuthorized == true;
    }

    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- Admin-Only Collections ---
    match /onboardingStages/{document=**} {
      allow read, write: if isAuthorized();
    }
    match /media/{document=**} {
        allow read, write: if isAuthorized();
    }
     match /modules/{document=**} {
      allow read, write: if isAuthorized();
    }
    
    // Messaging Engine Rules
    match /sender_profiles/{profileId} {
      allow read, write: if isAuthorized();
    }
    match /message_styles/{styleId} {
      allow read, write: if isAuthorized();
    }
    match /message_templates/{templateId} {
      allow read, write: if isAuthorized();
    }
    match /message_logs/{logId} {
      allow read, list: if isAuthorized();
      // Logs are created via server actions using admin SDK generally, 
      // but we allow read for audit UI.
    }

    // --- School Rules ---
    match /schools/{schoolId} {
      allow write: if isAuthorized();
      allow read: if true;
    }
    
    // --- Meeting Rules ---
    match /meetings/{meetingId} {
        allow write: if isAuthorized();
        allow read: if true;

        match /attendees/{attendeeId} {
          allow create: if true;
          allow read, list, update, delete: if isAuthorized();
        }
    }
    
    // --- User-Specific Rules ---
    match /dashboardLayouts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // --- User Management Rules ---
    match /users/{userId} {
      allow list, write: if isAuthorized();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow get: (isSignedIn() && request.auth.uid == userId) || isAuthorized();
    }
    
    // --- Survey Rules ---
    match /surveys/{surveyId} {
      allow write: if isAuthorized();
      allow get: resource.data.status == 'published' || isAuthorized();
      allow list: if isAuthorized();
    }

    match /surveys/{surveyId}/responses/{responseId} {
      allow create: if get(/databases/$(database)/documents/surveys/$(surveyId)).data.status == 'published';
      allow read, list, delete: if isAuthorized();
    }

    match /surveys/{surveyId}/summaries/{summaryId} {
      allow create, read, list, delete: if isAuthorized();
    }

    // --- Doc Signing Rules ---
    match /pdfs/{pdfId} {
      allow write, list: if isAuthorized();
      allow get: resource.data.status == 'published' || resource.data.resultsShared == true || isAuthorized();
      
      match /submissions/{submissionId} {
        allow create: if get(/databases/$(database)/documents/pdfs/$(pdfId)).data.status == 'published';
        
        // Allow public to read/list submissions if the admin has explicitly enabled results sharing
        allow read, list: if get(/databases/$(database)/documents/pdfs/$(pdfId)).data.resultsShared == true || isAuthorized();
        
        allow update, delete: if isAuthorized();
      }
    }

    // --- Activity Log Rules ---
    match /activities/{activityId} {
      allow create: if isAuthorized();
      allow read, list: if isAuthorized();
      allow update, delete: if request.auth.uid == resource.data.userId && resource.data.type == 'note';
    }
  }
}