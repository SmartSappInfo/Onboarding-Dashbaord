rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAuthorized == true)
      );
    }

    function getRoles() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    function hasRole(role) {
      return isAuthorized() && getRoles().hasAny([role]);
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isFinance() {
      return hasRole('finance') || isAdmin();
    }

    function isSupervisor() {
      return hasRole('supervisor') || isAdmin();
    }

    function isTrainer() {
      return hasRole('trainer') || isAdmin();
    }

    function isAnyAdmin() {
      return isAdmin() || isFinance() || isSupervisor() || isTrainer();
    }

    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- Billing & Contracts Rules ---
    match /subscription_packages/{packageId} {
      allow read: if isAnyAdmin();
      allow write: if isFinance();
    }
    match /billing_periods/{periodId} {
      allow read: if isAnyAdmin();
      allow write: if isFinance();
    }
    match /invoices/{invoiceId} {
      allow read: if isAnyAdmin() || true; // Public read for public invoice page
      allow write: if isFinance();
    }
    match /billing_settings/{settingId} {
      allow read: if isAnyAdmin();
      allow write: if isFinance();
    }
    match /contracts/{contractId} {
      allow read: if isAnyAdmin();
      allow write: if isFinance();
    }

    match /onboardingStages/{document=**} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    match /media/{document=**} {
        allow read, write: if isAuthorized();
    }
     match /modules/{document=**} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    match /webhooks/{document=**} {
      allow read, write: if isAdmin() || isSupervisor();
    }
    match /zones/{document=**} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    match /messaging_variables/{document=**} {
      allow read, write: if isAnyAdmin();
    }
    
    match /sender_profiles/{profileId} {
      allow read, write: if isAdmin() || isSupervisor();
    }
    match /message_styles/{styleId} {
      allow read, write: if isAdmin() || isSupervisor();
    }
    match /message_templates/{templateId} {
      allow read, write: if isAdmin() || isSupervisor();
    }
    match /message_logs/{logId} {
      allow read, list: if isAuthorized();
    }
    match /message_jobs/{jobId} {
      allow read, write: if isAuthorized();
      match /tasks/{taskId} {
        allow read, write: if isAuthorized();
      }
    }

    match /tasks/{taskId} {
      allow read, write: if isAuthorized();
    }

    match /automations/{ruleId} {
      allow read, write: if isAdmin();
    }

    match /schools/{schoolId} {
      allow write: if isAuthorized();
      allow read: if true;
    }
    
    match /meetings/{meetingId} {
        allow write: if isAuthorized();
        allow read: if true;
        match /attendees/{attendeeId} {
          allow create: if true;
          allow read, list, update, delete: if isAuthorized();
        }
    }
    
    match /dashboardLayouts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow get, create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow list, delete: if isAdmin();
    }
    
    match /surveys/{surveyId} {
      allow write, list: if isSupervisor() || isAdmin() || isFinance();
      allow get: if isAnyAdmin() || resource.data.status == 'published';
      match /resultPages/{pageId} {
        allow read: if true;
        allow write: if isSupervisor() || isAdmin() || isFinance();
      }
      match /responses/{responseId} {
        allow create: if get(/databases/$(database)/documents/surveys/$(surveyId)).data.status == 'published';
        allow read, list, delete: if isAuthorized();
      }
      match /summaries/{summaryId} {
        allow create, read, list, delete: if isAuthorized();
      }
    }

    match /pdfs/{pdfId} {
      allow write, list: if isSupervisor() || isAdmin() || isFinance();
      allow get: if isAnyAdmin() || resource.data.status == 'published' || resource.data.resultsShared == true;
      match /submissions/{submissionId} {
        allow create: if get(/databases/$(database)/documents/pdfs/$(pdfId)).data.status == 'published';
        allow read, list: if get(/databases/$(database)/documents/pdfs/$(pdfId)).data.resultsShared == true || isAuthorized();
        allow update, delete: if isAuthorized();
      }
    }

    match /activities/{activityId} {
      allow create: if isAuthorized() || isSignedIn();
      allow read, list: if isAuthorized();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId && resource.data.type == 'note';
    }

    match /survey_sessions/{sessionId} {
      allow create, update: if true;
      allow read, list: if isAuthorized();
    }

    match /pdf_sessions/{sessionId} {
      allow create, update: if true;
      allow read, list: if isAuthorized();
    }

    match /campaign_sessions/{sessionId} {
      allow read, list, create, update: if true;
    }
  }
}