
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAuthorized() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().isAuthorized == true)
      );
    }

    function hasPermission(perm) {
      return isAuthorized() && (
        getUserData().permissions.hasAny([perm]) || 
        getUserData().permissions.hasAny(['system_admin'])
      );
    }

    function isAdmin() {
      return hasPermission('system_admin');
    }

    function isFinance() {
      return hasPermission('finance_view');
    }

    function isSupervisor() {
      return hasPermission('system_user_switch');
    }

    // --- Institutional Track Logic ---
    function canAccessTrack(track) {
      return (track == 'onboarding' && hasPermission('schools_view')) ||
             (track == 'prospect' && hasPermission('prospects_view')) ||
             isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- Billing & Contracts Rules ---
    match /subscription_packages/{packageId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }
    match /billing_periods/{periodId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }
    match /invoices/{invoiceId} {
      allow read: if isAuthorized() || true; // Public read for public invoice page
      allow write: if hasPermission('finance_manage');
    }
    match /billing_settings/{settingId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }
    match /contracts/{contractId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }

    match /onboardingStages/{document=**} {
      allow read: if isAuthorized();
      allow write: if hasPermission('system_admin');
    }
    match /pipelines/{pipelineId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('system_admin');
    }
    match /media/{document=**} {
        allow read, write: if isAuthorized();
    }
     match /modules/{document=**} {
      allow read: if isAuthorized();
      allow write: if hasPermission('system_admin');
    }
    match /webhooks/{document=**} {
      allow read, write: if hasPermission('studios_edit');
    }
    match /zones/{document=**} {
      allow read: if isAuthorized();
      allow write: if hasPermission('system_admin');
    }
    match /messaging_variables/{document=**} {
      allow read, write: if isAuthorized();
    }
    
    match /sender_profiles/{profileId} {
      allow read, write: if hasPermission('studios_edit');
    }
    match /message_styles/{styleId} {
      allow read, write: if hasPermission('studios_edit');
    }
    match /message_templates/{templateId} {
      allow read, write: if hasPermission('studios_edit');
    }
    match /message_logs/{logId} {
      allow read, list: if isAuthorized();
    }
    match /message_jobs/{jobId} {
      allow read, write: if isAuthorized();
      match /tasks/{taskId} {
        allow read, write: if isAuthorized();
      }
    }

    match /tasks/{taskId} {
      allow read, write: if isAuthorized() && (
        resource == null || 
        request.auth.uid == resource.data.assignedTo || 
        canAccessTrack(resource.data.track)
      );
    }

    match /automations/{ruleId} {
      allow read, write: if hasPermission('system_admin');
    }

    match /schools/{schoolId} {
      allow read: if isAuthorized() ? canAccessTrack(resource.data.track) : true;
      allow create: if isAuthorized();
      allow update: if isAuthorized() && canAccessTrack(resource.data.track);
      allow delete: if hasPermission('system_admin');
    }
    
    match /meetings/{meetingId} {
        allow write: if isAuthorized();
        allow read: if true;
        match /attendees/{attendeeId} {
          allow create: if true;
          allow read, list, update, delete: if isAuthorized();
        }
    }
    
    match /dashboardLayouts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow get, create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasPermission('system_admin');
      allow list, delete: if hasPermission('system_admin');
    }
    
    match /roles/{roleId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('system_admin');
    }
    
    match /surveys/{surveyId} {
      allow write, list: if hasPermission('studios_edit');
      allow get: if isAuthorized() || resource.data.status == 'published';
      match /resultPages/{pageId} {
        allow read: if true;
        allow write: if hasPermission('studios_edit');
      }
      match /responses/{responseId} {
        allow create: if get(/databases/$(database)/documents/surveys/$(surveyId)).data.status == 'published';
        allow read, list, delete: if isAuthorized();
      }
      match /summaries/{summaryId} {
        allow create, read, list, delete: if isAuthorized();
      }
    }

    match /pdfs/{pdfId} {
      allow write, list: if hasPermission('studios_edit');
      allow get: if isAuthorized() || resource.data.status == 'published' || resource.data.resultsShared == true;
      match /submissions/{submissionId} {
        allow create: if get(/databases/$(database)/documents/pdfs/$(pdfId)).data.status == 'published';
        allow read, list: if get(/databases/$(database)/documents/pdfs/$(pdfId)).data.resultsShared == true || isAuthorized();
        allow update, delete: if isAuthorized();
      }
    }

    match /activities/{activityId} {
      allow create: if isAuthorized() || isSignedIn();
      allow read, list: if isAuthorized() && canAccessTrack(resource.data.track);
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId && resource.data.type == 'note';
    }

    match /survey_sessions/{sessionId} {
      allow create, update: if true;
      allow read, list: if isAuthorized();
    }

    match /pdf_sessions/{sessionId} {
      allow create, update: if true;
      allow read, list: if isAuthorized();
    }

    match /campaign_sessions/{sessionId} {
      allow read, list, create, update: if true;
    }
  }
}
