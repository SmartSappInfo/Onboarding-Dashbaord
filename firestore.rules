rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }

    // Schools can be read by anyone for meeting pages,
    // but only listed and written by admins.
    match /schools/{schoolId} {
      allow get: if true;
      allow list, create, update, delete: if request.auth != null;
    }

    // Meetings can be read by anyone for meeting pages,
    // but only listed and written by admins.
    match /meetings/{meetingId} {
        allow get: if true;
        allow list, create, update, delete: if request.auth != null;
    }

    // Media can only be accessed by admins.
    match /media/{mediaId} {
      allow read, write: if request.auth != null;
    }
  }
}
