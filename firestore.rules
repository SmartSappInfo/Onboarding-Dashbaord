
rules_version = '2';

// Triggering synchronization for multi-workspace sharing logic.
// Update: Applied array-contains logic for Schools/Contacts shared visibility.

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSystemAdmin() {
      return isSignedIn() && request.auth.token.get('email', '') == 'admin@smartsapp.com';
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function isAuthorized() {
      if (!isSignedIn()) return false;
      if (isSystemAdmin()) return true;
      
      let data = getUserData();
      return data != null && data.get('isAuthorized', false) == true;
    }

    function isAdmin() {
      if (!isSignedIn()) return false;
      if (isSystemAdmin()) return true;
      
      let data = getUserData();
      return data != null && data.get('permissions', []).hasAny(['system_admin']);
    }

    function hasPermission(perm) {
      if (!isSignedIn()) return false;
      if (isSystemAdmin()) return true;
      if (!isAuthorized()) return false;
      
      let data = getUserData();
      if (data == null) return false;
      let perms = data.get('permissions', []);
      return perms.hasAny([perm]) || perms.hasAny(['system_admin']);
    }

    // --- Workspace Access Logic ---
    function canAccessWorkspace(workspaceIds) {
      if (isSystemAdmin()) return true;
      if (!isAuthorized()) return false;
      
      let data = getUserData();
      if (data == null) return false;
      let perms = data.get('permissions', []);
      if (perms.hasAny(['system_admin'])) return true;
      
      if (workspaceIds == null) return false;
      
      // If any of the doc's workspaces are allowed by user perms
      return (workspaceIds.hasAny(['onboarding']) && perms.hasAny(['schools_view'])) || 
             (workspaceIds.hasAny(['prospect']) && perms.hasAny(['prospects_view']));
    }

    match /{document=**} {
      allow read, write: if false;
    }
    
    match /workspaces/{wId} {
        allow read: if isAuthorized();
        allow write: if isAdmin();
    }

    match /subscription_packages/{packageId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }
    match /billing_periods/{periodId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }
    match /invoices/{invoiceId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }
    match /billing_settings/{settingId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }
    match /contracts/{contractId} {
      allow read: if isAuthorized();
      allow write: if hasPermission('finance_manage');
    }

    match /onboardingStages/{document=**} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    match /pipelines/{pipelineId} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    match /media/{mediaId} {
        allow read: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.get('workspaceIds', [])));
        allow write: if isAuthorized();
    }
    match /zones/{document=**} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    match /messaging_variables/{document=**} {
      allow read, write: if isAuthorized();
    }
    
    match /sender_profiles/{profileId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.get('workspaceIds', [])));
      allow list: if isAuthorized();
      allow write: if hasPermission('studios_edit');
    }
    match /message_styles/{styleId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.get('workspaceIds', [])));
      allow list: if isAuthorized();
      allow write: if hasPermission('studios_edit');
    }
    match /message_templates/{templateId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.get('workspaceIds', [])));
      allow list: if isAuthorized();
      allow write: if hasPermission('studios_edit');
    }
    match /message_logs/{logId} {
      allow read, list: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.get('workspaceIds', [])));
    }
    match /message_jobs/{jobId} {
      allow read: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.get('workspaceIds', [])));
      allow write: if isAuthorized();
    }

    match /tasks/{taskId} {
      allow read, write: if isAuthorized() && (
        isSystemAdmin() ||
        isAdmin() || 
        request.auth.uid == resource.data.assignedTo || 
        canAccessWorkspace([resource.data.get('workspaceId', 'onboarding')])
      );
    }

    match /automations/{ruleId} {
      allow read, write: if isAdmin() || isSystemAdmin() || (exists(resource) && canAccessWorkspace([resource.data.get('workspaceId', 'onboarding')]));
    }

    match /schools/{schoolId} {
      allow get: if !isAuthorized() || canAccessWorkspace(resource.data.get('workspaceIds', []));
      allow list: if isAuthorized(); 
      allow create: if isAuthorized();
      allow update: if isAuthorized();
      allow delete: if isAdmin();
    }
    
    match /meetings/{meetingId} {
        allow write: if isAuthorized();
        allow read: if true;
        match /attendees/{attendeeId} {
          allow create: if true;
          allow read, list, update, delete: if isAuthorized();
        }
    }
    
    match /dashboardLayouts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow get, create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow list, delete: if isAdmin();
    }
    
    match /roles/{roleId} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    
    match /surveys/{surveyId} {
      allow write, list: if hasPermission('studios_edit');
      allow get: if isAuthorized() || (exists(/databases/$(database)/documents/surveys/$(surveyId)) && get(/databases/$(database)/documents/surveys/$(surveyId)).data.status == 'published');
      match /responses/{responseId} {
        allow create: if get(/databases/$(database)/documents/surveys/$(surveyId)).data.status == 'published';
        allow read, list, delete: if isAuthorized();
      }
    }

    match /pdfs/{pdfId} {
      allow write, list: if hasPermission('studios_edit');
      allow get: if isAuthorized() || (exists(/databases/$(database)/documents/pdfs/$(pdfId)) && get(/databases/$(database)/documents/pdfs/$(pdfId)).data.status == 'published');
      match /submissions/{submissionId} {
        allow create: if get(/databases/$(database)/documents/pdfs/$(pdfId)) != null && get(/databases/$(database)/documents/pdfs/$(pdfId)).data.status == 'published';
        allow read, list: if isAuthorized();
      }
    }

    match /activities/{activityId} {
      allow create: if isAuthorized() || isSignedIn();
      allow read, list: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.get('workspaceIds', [])));
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId && resource.data.type == 'note';
    }

    match /survey_sessions/{sessionId} {
      allow create, update: if true;
      allow read, list: if isAuthorized();
    }

    match /campaign_sessions/{sessionId} {
      allow read, list, create, update: if true;
    }
  }
}
