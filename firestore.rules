// Deployment fix for organizations list permission
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAuthorized() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (getUserData() != null && getUserData().get('isAuthorized', false) == true)
      );
    }

    function isSystemAdmin() {
      let data = getUserData();
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (data != null && data.get('isAuthorized', false) == true && 
         data.get('permissions', []).hasAny(['system_admin']))
      );
    }

    function isOrgMatch(orgId) {
      let data = getUserData();
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (data != null && data.get('organizationId', '') == orgId)
      );
    }

    function hasPermission(perm) {
      let data = getUserData();
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (data != null && data.get('isAuthorized', false) == true && 
         (data.get('permissions', []).hasAny([perm]) || data.get('permissions', []).hasAny(['system_admin'])))
      );
    }

    function canAccessWorkspace(targetWorkspaceIds) {
      let data = getUserData();
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (data != null && data.get('isAuthorized', false) == true && 
         (data.get('permissions', []).hasAny(['system_admin']) || 
          data.get('workspaceIds', []).hasAny(targetWorkspaceIds)))
      );
    }

    // Industry-specific helper function
    // Requirement 10.9: Validate collection access based on Workspace Industry_Vertical
    // Requirement 16.8: Gate read/write on hasWorkspaceAccess AND workspaceIndustryMatches
    function workspaceIndustryMatches(workspaceId, requiredIndustry) {
      let workspacePath = /databases/$(database)/documents/workspaces/$(workspaceId);
      return exists(workspacePath) && get(workspacePath).data.industry == requiredIndustry;
    }

    function hasWorkspaceAccess(workspaceId) {
      let data = getUserData();
      return isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        (data != null && data.get('isAuthorized', false) == true && 
         (data.get('permissions', []).hasAny(['system_admin']) || 
          workspaceId in data.get('workspaceIds', [])))
      );
    }

    // --- Base Deny-All ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Shared Reference Data ---
    match /countries/{countryId} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isSystemAdmin();
    }

    match /regions/{regionId} {
      allow read: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow write: if isAuthorized() && (isSystemAdmin() || isOrgMatch(request.resource.data.organizationId));
    }

    match /districts/{districtId} {
      allow read: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow write: if isAuthorized() && (isSystemAdmin() || isOrgMatch(request.resource.data.organizationId));
    }

    match /modules/{moduleId} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isSystemAdmin();
    }

    // --- Governance Layer (Org Bound) ---
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (isSystemAdmin() || isOrgMatch(orgId));
      allow write: if isSystemAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isSystemAdmin() || isAuthorized());
      allow list: if isSignedIn() && (isSystemAdmin() || isAuthorized());
      allow update: if isSignedIn() && isSystemAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId; 
    }

    match /roles/{roleId} {
      allow get: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && isSystemAdmin();
    }

    match /billing_profiles/{profileId} {
      allow get: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow list: if isSystemAdmin() || (isAuthorized() && canAccessWorkspace(resource.data.workspaceIds));
      allow write: if isAuthorized() && (isSystemAdmin() || (hasPermission('finance_manage') && isOrgMatch(request.resource.data.organizationId)));
    }

    match /verification_cache/{docId} {
      allow read: if isAuthorized();
    }

    match /workspaces/{workspaceId} {
      allow get: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow list: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || isAuthorized());
      allow write: if isAuthorized() && (request.auth.token.email == 'admin@smartsapp.com' || isSystemAdmin());
    }

    // --- Operational Layer (Workspace Shared Array) ---
    match /schools/{schoolId} {
      allow get: if !isAuthorized() || canAccessWorkspace(resource.data.workspaceIds);
      allow list: if isAuthorized();
      allow create: if isAuthorized();
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        canAccessWorkspace(resource.data.workspaceIds) ||
        // Allow tag-only updates with schools_edit permission
        (hasPermission('schools_edit') &&
         canAccessWorkspace(resource.data.workspaceIds) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tags', 'taggedAt', 'taggedBy']))
      );
      allow delete: if isAuthorized() && hasPermission('system_admin') && canAccessWorkspace(resource.data.workspaceIds);
    }

    match /pipelines/{pId} {
      allow get: if isSystemAdmin() || (isAuthorized() && canAccessWorkspace(resource.data.workspaceIds));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && hasPermission('system_admin') && canAccessWorkspace(request.resource.data.workspaceIds);
    }

    match /onboardingStages/{stageId} {
      allow get: if isAuthorized();
      allow list: if isAuthorized();
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        canAccessWorkspace(get(/databases/$(database)/documents/pipelines/$(request.resource.data.pipelineId)).data.workspaceIds)
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (canAccessWorkspace(get(/databases/$(database)/documents/pipelines/$(resource.data.pipelineId)).data.workspaceIds) &&
         request.resource.data.pipelineId == resource.data.pipelineId)
      );
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        canAccessWorkspace(get(/databases/$(database)/documents/pipelines/$(resource.data.pipelineId)).data.workspaceIds)
      );
    }

    match /deals/{dealId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(resource.data.workspaceId)
      );
      // Allow list if user is system admin or authorized with workspace access
      // Special case: admin@smartsapp.com always has access
      allow list: if isSignedIn() && (
        request.auth.token.email == 'admin@smartsapp.com' ||
        isSystemAdmin() ||
        (isAuthorized() && getUserData() != null && getUserData().workspaceIds.size() > 0)
      );
      allow create: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(request.resource.data.workspaceId)
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() || 
        (hasWorkspaceAccess(resource.data.workspaceId) && 
         request.resource.data.workspaceId == resource.data.workspaceId)
      );
      allow delete: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(resource.data.workspaceId)
      );
    }

    match /meetings/{meetingId} {
      allow read: if true; 
      allow create: if isAuthorized();
      allow list: if isAuthorized();
      allow update, delete: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds));
      
      match /attendees/{aId} {
        allow create: if true;
        allow read, list: if isAuthorized();
      }

      match /registrants/{rId} {
        allow create: if true;
        allow read, list, update: if isAuthorized();
      }
    }

    match /custom_meeting_templates/{templateId} {
      allow get, list: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || isAuthorized());
      allow create: if isAuthorized() && (isSystemAdmin() || hasWorkspaceAccess(request.resource.data.workspaceId));
      allow update, delete: if isAuthorized() && (isSystemAdmin() || hasWorkspaceAccess(resource.data.workspaceId));
    }

    match /invoices/{invoiceId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && hasPermission('finance_manage') && canAccessWorkspace(request.resource.data.workspaceIds);
    }

    match /billing_periods/{periodId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && isSystemAdmin();
    }

    match /subscription_packages/{pkgId} {
      allow get: if (isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds))) || resource.data.isActive == true;
      allow list: if isSystemAdmin() || (isAuthorized() && canAccessWorkspace(resource.data.workspaceIds)) || resource.data.isActive == true;
      allow write: if isAuthorized() && isSystemAdmin();
    }

    match /surveys/{surveyId} {
      allow get: if isAuthorized() || resource.data.status == 'published';
      allow list: if isAuthorized();
      allow write: if isAuthorized() && hasPermission('studios_edit') && canAccessWorkspace(request.resource.data.workspaceIds);

      match /responses/{rId} {
        allow create: if true;
        allow read, list: if isAuthorized();
      }
      match /summaries/{sId} {
        allow read, list, write: if isAuthorized();
      }
      match /resultPages/{pId} {
        allow read: if true;
        allow write: if isAuthorized();
      }
    }

    match /pdfs/{pdfId} {
      allow get: if isAuthorized() || resource.data.status == 'published';
      allow list: if isAuthorized();
      allow write: if isAuthorized() && hasPermission('studios_edit') && canAccessWorkspace(request.resource.data.workspaceIds);

      match /submissions/{sId} {
        allow create: if true;
        allow read, list: if isAuthorized();
      }
    }

    match /media/{mediaId} {
      allow get, list: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || isAuthorized());
      allow create: if isAuthorized();
      allow update, delete: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds));
    }

    // --- Message Templates (Two-Tier System) ---
    // Task 16.1: Security rules for message_templates collection
    // Global templates: read by all authenticated users, write only by super admins
    // Org templates: read/write scoped to matching organizationId
    match /message_templates/{tId} {
      // Read access: all authorized users can read templates
      // Global templates are accessible to all
      // Org templates should be filtered by application layer
      // Using 'read' instead of separate 'get' and 'list' to avoid permission conflicts
      allow read: if isAuthorized();
      
      // Write access for global templates: super admins only
      allow create: if isAuthorized() && (
        (request.resource.data.scope == 'global' && isSystemAdmin()) ||
        (request.resource.data.scope == 'organization' && 
         hasPermission('studios_edit') && 
         isOrgMatch(request.resource.data.organizationId))
      );
      
      allow update: if isAuthorized() && (
        (resource.data.scope == 'global' && isSystemAdmin()) ||
        (resource.data.scope == 'organization' && 
         hasPermission('studios_edit') && 
         isOrgMatch(resource.data.organizationId) &&
         // Prevent scope or organizationId changes
         request.resource.data.scope == resource.data.scope &&
         request.resource.data.organizationId == resource.data.organizationId)
      );
      
      allow delete: if isAuthorized() && (
        (resource.data.scope == 'global' && isSystemAdmin()) ||
        (resource.data.scope == 'organization' && 
         hasPermission('studios_edit') && 
         isOrgMatch(resource.data.organizationId))
      );
    }

    // --- Template Variables Registry ---
    // Task 16.2: Security rules for template_variables collection
    // Read: all authenticated users (needed for template editor and composer)
    // Write: super admins and org admins (for dynamic form/survey variable registration)
    match /template_variables/{varId} {
      // Read access: all authenticated users can read variables
      allow get, list: if isAuthorized();
      
      // Write access: super admins can write all variables
      // Org admins can write variables scoped to their organization
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && 
         (!request.resource.data.keys().hasAny(['organizationId']) || 
          isOrgMatch(request.resource.data.organizationId)))
      );
      
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && 
         (!resource.data.keys().hasAny(['organizationId']) || 
          isOrgMatch(resource.data.organizationId)))
      );
      
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && 
         (!resource.data.keys().hasAny(['organizationId']) || 
          isOrgMatch(resource.data.organizationId)))
      );
    }

    // --- Scheduled Messages (Reminder System) ---
    // Task 16.3: Security rules for scheduled_messages collection
    // Read/write scoped to organizationId
    match /scheduled_messages/{msgId} {
      // Read access: users in matching organization
      allow get: if isAuthorized() && (
        isSystemAdmin() ||
        isOrgMatch(resource.data.organizationId)
      );
      
      // List access: all authorized users (filtering by org happens in queries)
      allow list: if isAuthorized();
      
      // Create: users in matching organization with appropriate permissions
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        isOrgMatch(request.resource.data.organizationId)
      );
      
      // Update: users in matching organization
      // Prevent organizationId changes
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (isOrgMatch(resource.data.organizationId) &&
         request.resource.data.organizationId == resource.data.organizationId)
      );
      
      // Delete: super admins or users in matching organization
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        isOrgMatch(resource.data.organizationId)
      );
    }

    match /sender_profiles/{pId} {
      // Allow read for all authorized users - workspace filtering happens in queries
      allow read: if isAuthorized();
      allow write: if isAuthorized() && hasPermission('studios_edit') && canAccessWorkspace(request.resource.data.workspaceIds);
    }

    match /message_styles/{sId} {
      // Allow read for all authorized users - workspace filtering happens in queries
      allow read: if isAuthorized();
      allow write: if isAuthorized() && (
        isSystemAdmin() ||
        (
          request.method != 'delete' &&
          (!request.resource.data.keys().hasAll(['scope']) || request.resource.data.scope != 'global') &&
          (resource == null || !resource.data.keys().hasAll(['scope']) || resource.data.scope != 'global') &&
          hasPermission('studios_edit') &&
          canAccessWorkspace(request.resource.data.workspaceIds)
        ) ||
        (
          request.method == 'delete' &&
          (!resource.data.keys().hasAll(['scope']) || resource.data.scope != 'global') &&
          hasPermission('studios_edit') &&
          canAccessWorkspace(resource.data.workspaceIds)
        )
      );
    }

    match /automations/{aId} {
      // Allow read for all authorized users - workspace filtering happens in queries
      allow read: if isAuthorized();
      allow write: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(request.resource.data.workspaceIds));
    }

    // --- Operational Layer (Strict Workspace Confinement) ---
    match /tasks/{taskId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() || 
        (getUserData() != null && resource.data.workspaceId in getUserData().get('workspaceIds', []))
      );
      allow list: if isAuthorized();
      allow write: if isAuthorized() && (
        isSystemAdmin() || 
        (getUserData() != null && resource.data.workspaceId in getUserData().get('workspaceIds', []))
      );
    }

    match /activities/{activityId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() || 
        (getUserData() != null && resource.data.workspaceId in getUserData().get('workspaceIds', []))
      );
      allow list: if isAuthorized();
      allow create: if isAuthorized() || isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId && resource.data.type == 'note';
    }

    match /message_logs/{logId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds));
      allow list: if isAuthorized();
    }

    // --- Message Campaigns ---
    // Campaign management for bulk messaging
    match /message_campaigns/{campaignId} {
      // Read access: users in matching workspace
      allow get: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(resource.data.workspaceId)
      );
      
      // List access: all authorized users (filtering by workspace happens in queries)
      allow list: if isAuthorized();
      
      // Create: users with workspace access
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        (hasWorkspaceAccess(request.resource.data.workspaceId) &&
         isOrgMatch(request.resource.data.organizationId))
      );
      
      // Update: users with workspace access
      // Prevent workspace and organization changes
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (hasWorkspaceAccess(resource.data.workspaceId) &&
         isOrgMatch(resource.data.organizationId) &&
         request.resource.data.workspaceId == resource.data.workspaceId &&
         request.resource.data.organizationId == resource.data.organizationId)
      );
      
      // Delete: super admins or users with workspace access
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(resource.data.workspaceId)
      );
    }

    // --- Message Audiences ---
    match /message_audiences/{audienceId} {
      allow read: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || isAuthorized());
      allow write: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || (isAuthorized() && (isSystemAdmin() || hasWorkspaceAccess(request.resource.data.workspaceId))));
    }

    // --- In-App Notifications ---
    // User-specific notifications displayed in the notification center
    match /in_app_notifications/{notificationId} {
      // Users can only read their own notifications
      allow get: if isSignedIn() && request.auth.uid == resource.data.userId;
      
      // List with userId filter
      allow list: if isSignedIn();
      
      // Users can mark their own notifications as read
      allow update: if isSignedIn() && 
                       request.auth.uid == resource.data.userId &&
                       request.resource.data.userId == resource.data.userId;
      
      // Only system can create notifications
      allow create: if isAuthorized();
      
      // Only system admin can delete
      allow delete: if isSystemAdmin();
    }

    // --- Entity Migration Security Rules (Requirement 29) ---
    
    /**
     * Enhanced security rules for feature collections using entityId
     * These rules enforce workspace boundaries and prevent cross-workspace data leakage
     * during and after the schoolId to entityId migration.
     */
    
    // Forms collection - dual-write migration support
    match /forms/{formId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(resource.data.workspaceId) ||
        resource.data.status == 'published'
      );
      allow list: if isAuthorized() && (
        isSystemAdmin() ||
        hasPermission('studios_edit')
      );
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && 
         hasWorkspaceAccess(request.resource.data.workspaceId))
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && 
         hasWorkspaceAccess(resource.data.workspaceId) &&
         request.resource.data.workspaceId == resource.data.workspaceId)
      );
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && 
         hasWorkspaceAccess(resource.data.workspaceId))
      );
    }
    
    // Form submissions - workspace boundary enforcement
    match /forms/{formId}/submissions/{submissionId} {
      allow read: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(get(/databases/$(database)/documents/forms/$(formId)).data.workspaceId)
      );
      allow create: if true; // Public form submissions
      allow update, delete: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(get(/databases/$(database)/documents/forms/$(formId)).data.workspaceId)
      );
    }
    
    // Automation logs - workspace boundary enforcement
    match /automation_logs/{logId} {
      // Unified read: allows both get and list without permission conflicts.
      allow read: if isAuthorized();
      allow create: if isAuthorized();
      allow update, delete: if isAuthorized() && isSystemAdmin();
    }
    
    // Entity audit logs - immutable audit trail
    match /entity_audit_logs/{logId} {
      // Unified read: allows both get and list without permission conflicts.
      allow read: if isAuthorized() && (isSystemAdmin() || hasPermission('activities_view'));
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable audit logs
    }
    // --- Import Logs & Data Ingestion ---
    match /import_logs/{logId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(resource.data.workspaceId)
      );
      allow list: if isAuthorized();
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(request.resource.data.workspaceId)
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(resource.data.workspaceId)
      );
      allow delete: if isAuthorized() && isSystemAdmin();
    }

    match /import_logs/{logId}/failed_rows/{rowId} {
      allow read, write: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(get(/databases/$(database)/documents/import_logs/$(logId)).data.workspaceId)
      );
    }

    // --- System / Analytics ---
    match /automation_runs/{runId} {
      allow read, list: if isAuthorized();
    }
    match /automation_jobs/{jobId} {
      allow read, list: if isAuthorized();
    }
    match /survey_sessions/{sId} {
      allow create, update: if true;
      allow read, list: if isAuthorized();
    }
    match /campaign_sessions/{sId} {
      allow read, list, create, update: if true;
    }
    match /webhooks/{webhookId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(resource.data.workspaceId)
      );
      allow list: if isAuthorized();
      allow create: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(request.resource.data.workspaceId)
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() || 
        (hasWorkspaceAccess(resource.data.workspaceId) && 
         request.resource.data.workspaceId == resource.data.workspaceId)
      );
      allow delete: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(resource.data.workspaceId)
      );
    }
    match /messaging_variables/{vId} {
      allow read, write: if isAuthorized();
    }

    // --- Landing Pages / Campaign Pages ---
    match /campaign_pages/{pageId} {
      allow get: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && (isSystemAdmin() || hasPermission('studios_edit'));
    }

    match /campaign_page_versions/{vId} {
      allow get: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && (isSystemAdmin() || hasPermission('studios_edit'));
    }

    match /page_templates/{tId} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isSystemAdmin();
    }

    // --- Contracts ---
    match /contracts/{contractId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && (isSystemAdmin() || (hasPermission('finance_manage') && canAccessWorkspace(request.resource.data.workspaceIds)));
    }

    // --- Perspectives ---
    match /perspectives/{pId} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isSystemAdmin();
    }

    // --- Zones ---
    match /zones/{zoneId} {
      allow get: if isAuthorized() && (isSystemAdmin() || isOrgMatch(resource.data.organizationId));
      allow list: if isAuthorized();
      allow write: if isAuthorized() && (isSystemAdmin() || hasPermission('schools_edit'));
    }

    // --- PDF Sessions ---
    match /pdf_sessions/{sId} {
      allow read, write: if isAuthorized();
    }

    // --- Message Jobs ---
    match /message_jobs/{jobId} {
      allow get: if isAuthorized() && (isSystemAdmin() || canAccessWorkspace(resource.data.workspaceIds));
      allow list: if isAuthorized();
      allow write: if isAuthorized();
    }

    // --- Attendees (top-level) ---
    match /attendees/{aId} {
      allow create: if true;
      allow read, list: if isAuthorized();
      allow update, delete: if isAuthorized() && isSystemAdmin();
    }

    // --- Audit Logs ---
    match /audit_logs/{logId} {
      allow read, list: if isAuthorized() && (isSystemAdmin() || hasPermission('activities_view'));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- Dashboard Layouts ---
    match /dashboardLayouts/{layoutId} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && (isSystemAdmin() || hasPermission('dashboard_manage'));
    }

    match /dashboards/{docId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(resource.data.workspaceId)
      );
      allow write: if isAuthorized() && (
        isSystemAdmin() || 
        hasWorkspaceAccess(request.resource.data.workspaceId)
      );
    }

    // --- App Fields / Variable Registry ---
    match /app_fields/{fieldId} {
      allow read: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || isAuthorized());
      allow create: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || (isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && hasWorkspaceAccess(request.resource.data.workspaceId))
      )));
      allow update: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || (isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && hasWorkspaceAccess(resource.data.workspaceId))
      )));
      allow delete: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || (isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && hasWorkspaceAccess(resource.data.workspaceId))
      )));
    }

    match /field_groups/{groupId} {
      allow get, list: if isSignedIn() && (request.auth.token.email == 'admin@smartsapp.com' || isAuthorized());
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && hasWorkspaceAccess(request.resource.data.workspaceId))
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && hasWorkspaceAccess(resource.data.workspaceId))
      );
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('studios_edit') && hasWorkspaceAccess(resource.data.workspaceId))
      );
    }

    // --- Contact Tagging System ---
    match /tags/{tagId} {
      // Unified read: allows both get and list without permission conflicts.
      allow read: if isAuthorized();
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('tags_manage') && hasWorkspaceAccess(request.resource.data.workspaceId))
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('tags_manage') &&
         hasWorkspaceAccess(resource.data.workspaceId) &&
         resource.data.get('isSystem', false) == false)
      );
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        (hasPermission('tags_manage') &&
         hasWorkspaceAccess(resource.data.workspaceId) &&
         resource.data.get('isSystem', false) == false)
      );
    }

    match /tag_audit_logs/{logId} {
      // Unified read: allows both get and list without permission conflicts.
      allow read: if isAuthorized();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }



    match /entities/{entityId} {
      // Admin bypass - check first to avoid expensive getUserData() calls
      allow read, write: if request.auth != null && request.auth.token.email == 'admin@smartsapp.com';
      
      allow get: if isAuthorized() && (
        isSystemAdmin() ||
        isOrgMatch(resource.data.organizationId)
      );
      allow list: if isAuthorized();
      
      // Allow create if user has schools_edit permission
      allow create: if isSystemAdmin() ||
        (isAuthorized() &&
         hasPermission('schools_edit') && 
         isOrgMatch(request.resource.data.organizationId));
      
      // Allow update if user has schools_edit permission
      // Requirement 29.3: Verify user permissions for entity updates
      allow update: if isSystemAdmin() ||
        (isAuthorized() &&
         hasPermission('schools_edit') && 
         isOrgMatch(resource.data.organizationId) &&
         // Prevent organization change
         request.resource.data.organizationId == resource.data.organizationId);
      
      // Allow delete if user has system_admin permission
      allow delete: if isAuthorized() && isSystemAdmin();
    }

    match /entity_notes/{noteId} {
      // Unified read: allows both get and list without permission conflicts.
      allow read: if isAuthorized();
      allow create: if isAuthorized() && (
        isSystemAdmin() ||
        hasWorkspaceAccess(request.resource.data.workspaceId)
      );
      allow update: if isAuthorized() && (
        isSystemAdmin() ||
        (hasWorkspaceAccess(resource.data.workspaceId) &&
         request.resource.data.workspaceId == resource.data.workspaceId &&
         request.auth.uid == resource.data.createdBy)
      );
      allow delete: if isAuthorized() && (
        isSystemAdmin() ||
        (hasWorkspaceAccess(resource.data.workspaceId) &&
         request.auth.uid == resource.data.createdBy)
      );
    }

    match /workspace_entities/{workspaceEntityId} {
      // Requirement 9.5: Immediately deny reads/writes when workspace access is revoked
      // Requirement 29.1: Enforce workspace boundaries for workspace_entities
      // Requirement 29.2: Verify user permissions for entity updates
      // Requirement 29.5: Prevent cross-workspace data leakage
      // 
      // CRITICAL: The user.workspaceIds array MUST be kept in sync with role-based access.
      // When a user is removed from a role OR a workspace is removed from a role's workspaceIds,
      // the user.workspaceIds array MUST be updated immediately to ensure security rules
      // deny access without delay.
      //
      // This denormalization is necessary because Firestore security rules cannot perform
      // complex queries to check role membership dynamically.
      
      // Unified read: allows both get and list without permission conflicts.
      // Application-layer queries already filter by workspaceId.
      // Special case: admin@smartsapp.com always has access
      allow read: if request.auth != null && request.auth.token.email == 'admin@smartsapp.com';
      allow read: if isAuthorized();
      
      // Allow create if user has schools_edit permission and workspace access
      // Enforce ScopeGuard: entity.entityType must match workspace.contactScope
      allow create: if request.auth != null && request.auth.token.email == 'admin@smartsapp.com';
      allow create: if isSystemAdmin() ||
        (isAuthorized() &&
         hasPermission('schools_edit') &&
         hasWorkspaceAccess(request.resource.data.workspaceId) &&
         // ScopeGuard validation: entityType must match workspace contactScope
         request.resource.data.entityType == get(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.contactScope);
      
      // Allow update if user has schools_edit permission and workspace access
      // Requirement 29.3: Verify user permissions for entity updates
      allow update: if request.auth != null && request.auth.token.email == 'admin@smartsapp.com';
      allow update: if isSystemAdmin() ||
        (isAuthorized() &&
         hasPermission('schools_edit') &&
         hasWorkspaceAccess(resource.data.workspaceId) &&
         // Ensure workspace access is not changed to a workspace user doesn't have access to
         // This prevents cross-workspace data leakage
         request.resource.data.workspaceId == resource.data.workspaceId &&
         hasWorkspaceAccess(request.resource.data.workspaceId));
      
      // Allow delete if user has schools_edit permission and workspace access
      allow delete: if request.auth != null && request.auth.token.email == 'admin@smartsapp.com';
      allow delete: if isSystemAdmin() ||
        (isAuthorized() &&
         hasPermission('schools_edit') &&
         hasWorkspaceAccess(resource.data.workspaceId));
    }

    match /workspace_users/{docId} {
      allow read, list: if isAuthorized();
      allow write: if isSystemAdmin();
    }

    match /meeting_registrants/{docId} {
      allow create: if true;
      allow read, list, update: if isAuthorized();
      allow delete: if isSystemAdmin();
    }

    // --- Industry-Specific Collections ---
    // Requirement 10.9: Validate collection access based on Workspace Industry_Vertical
    // Requirement 16.8: Gate read/write on hasWorkspaceAccess AND workspaceIndustryMatches
    
    // SaaS Industry Collections
    match /trials/{trialId} {
      allow get: if isAuthorized() && (
        isSystemAdmin() ||
        (hasWorkspaceAccess(resource.data.workspaceId) && 
         workspaceIndustryMatches(resource.data.workspaceId, 'SaaS'))
