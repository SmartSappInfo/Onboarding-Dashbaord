rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read-only access to schools.
    match /schools/{schoolId} {
      allow get, list: if true;
      // For this project, we'll allow any authenticated user to act as an admin.
      // In a real-world scenario, this would check for a specific admin claim.
      allow create, update, delete: if request.auth != null;
    }

    // Allow public read-only access to meetings and admin write access.
    match /meetings/{meetingId} {
        allow get, list: if true;
        allow create, update, delete: if request.auth != null;
    }

    // Allow public read-only access to media assets and admin write access.
    match /media/{mediaId} {
      allow get, list: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
