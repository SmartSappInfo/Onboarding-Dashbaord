# E2E Test Environment Configuration
# Copy this file to .env.test and fill in with actual test account credentials

# Super Admin Test Account
# Required for: template-management.spec.ts
TEST_SUPER_ADMIN_EMAIL=superadmin@test.smartsapp.com
TEST_SUPER_ADMIN_PASSWORD=your_secure_password

# Organization Admin Test Account
# Required for: workspace-creation-industry.spec.ts, industry-feature-visibility.spec.ts
TEST_ORG_ADMIN_EMAIL=orgadmin@test.smartsapp.com
TEST_ORG_ADMIN_PASSWORD=your_secure_password

# Regular User Test Account
# Required for: general user flow tests
TEST_USER_EMAIL=user@test.smartsapp.com
TEST_USER_PASSWORD=your_secure_password

# Test Organization ID (optional)
# If you want to test against a specific organization
TEST_ORGANIZATION_ID=

# Firebase Emulator Configuration (optional)
# Set to true to run tests against Firebase emulators instead of production
TEST_USE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
