**Issue**: During migration, some code paths don't maintain dual-write consistency.

**Recommendation**: Create a centralized dual-write helper:
```typescript
async function dualWriteEntity(
  entityId: string,
  entityUpdate: any,
  workspaceEntityUpdate: any,
  workspaceId: string
) {
  const batch = adminDb.batch();
  
  // Update entities
  batch.update(adminDb.collection('entities').doc(entityId), entityUpdate);
  
  // Update workspace_entities
  const weId = `${workspaceId}_${entityId}`;
  batch.update(adminDb.collection('workspace_entities').doc(weId), workspaceEntityUpdate);
  
  // Update legacy schools if migrationStatus !== 'migrated'
  const entitySnap = await adminDb.collection('entities').doc(entityId).get();
  if (entitySnap.data()?.migrationStatus !== 'migrated') {
    batch.update(adminDb.collection('schools').doc(entityId), {
      ...entityUpdate,
      ...workspaceEntityUpdate
    });
  }
  
  await batch.commit();
}
```

