
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Administrative user data and authorization status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "color": { "type": "string" },
        "isAuthorized": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "School": {
      "title": "School",
      "description": "Details about an onboarding school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "location": { "type": "string" },
        "nominalRoll": { "type": "number" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "stage": { "type": "object" },
        "assignedTo": { "type": "object" },
        "modules": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Meeting": {
      "title": "Meeting",
      "description": "Onboarding session or parent engagement meeting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "schoolSlug": { "type": "string" },
        "meetingTime": { "type": "string", "format": "date-time" },
        "meetingLink": { "type": "string" },
        "type": { "type": "object" },
        "recordingUrl": { "type": "string" },
        "brochureUrl": { "type": "string" }
      }
    },
    "Survey": {
      "title": "Survey",
      "description": "Intelligent, scored feedback form.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "elements": { "type": "array" },
        "scoringEnabled": { "type": "boolean" },
        "maxScore": { "type": "number" }
      }
    },
    "PDFForm": {
      "title": "PDF Form",
      "description": "Interactive document mapping for digital signing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "publicTitle": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "fields": { "type": "array" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "Logged event in the activity timeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "schoolSlug": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "source": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "SenderProfile": {
      "title": "Sender Profile",
      "description": "Configured identity for sending SMS or Emails.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "channel": { "type": "string", "enum": ["sms", "email"] },
        "identifier": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MessageStyle": {
      "title": "Message Style",
      "description": "Visual HTML wrappers for branded emails.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "htmlWrapper": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MessageTemplate": {
      "title": "Message Template",
      "description": "Dynamic content definitions for communications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["forms", "surveys", "meetings", "general"] },
        "channel": { "type": "string", "enum": ["sms", "email"] },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "styleId": { "type": "string" },
        "variables": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MessageLog": {
      "title": "Message Log",
      "description": "Historical record of sent messages for audit and debugging.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "templateId": { "type": "string" },
        "templateName": { "type": "string" },
        "senderProfileId": { "type": "string" },
        "senderName": { "type": "string" },
        "channel": { "type": "string", "enum": ["sms", "email"] },
        "recipient": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "failed"] },
        "sentAt": { "type": "string", "format": "date-time" }
      }
    },
    "MessageJob": {
      "title": "Message Job",
      "description": "Batch operation tracking for bulk sends.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "processing", "completed", "failed"] },
        "totalRecipients": { "type": "number" },
        "processed": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles managed by admins."
    },
    "/schools/{schoolId}": {
      "schema": "#/entities/School",
      "description": "Schools in the onboarding pipeline."
    },
    "/meetings/{meetingId}": {
      "schema": "#/entities/Meeting",
      "description": "Meeting records."
    },
    "/meetings/{meetingId}/attendees/{attendeeId}": {
      "schema": "object",
      "description": "Meeting attendance logs."
    },
    "/surveys/{surveyId}": {
      "schema": "#/entities/Survey",
      "description": "Survey definitions."
    },
    "/surveys/{surveyId}/responses/{responseId}": {
      "schema": "object",
      "description": "Survey responses."
    },
    "/surveys/{surveyId}/summaries/{summaryId}": {
      "schema": "object",
      "description": "AI generated survey summaries."
    },
    "/pdfs/{pdfId}": {
      "schema": "#/entities/PDFForm",
      "description": "Doc signing templates."
    },
    "/pdfs/{pdfId}/submissions/{submissionId}": {
      "schema": "object",
      "description": "Signed document submissions."
    },
    "/activities/{activityId}": {
      "schema": "#/entities/Activity",
      "description": "Audit logs and interaction notes."
    },
    "/sender_profiles/{profileId}": {
      "schema": "#/entities/SenderProfile",
      "description": "Authorized sender identities."
    },
    "/message_styles/{styleId}": {
      "schema": "#/entities/MessageStyle",
      "description": "Branded HTML email wrappers."
    },
    "/message_templates/{templateId}": {
      "schema": "#/entities/MessageTemplate",
      "description": "Reusable message content definitions."
    },
    "/message_logs/{logId}": {
      "schema": "#/entities/MessageLog",
      "description": "Stateless logs of all messaging activity."
    },
    "/message_jobs/{jobId}": {
      "schema": "#/entities/MessageJob",
      "description": "Registry for bulk messaging operations."
    },
    "/onboardingStages/{stageId}": {
      "schema": "object",
      "description": "Configuration for pipeline stages."
    },
    "/modules/{moduleId}": {
      "schema": "object",
      "description": "Configuration for SmartSapp modules."
    },
    "/dashboardLayouts/{userId}": {
      "schema": "object",
      "description": "User specific dashboard widget ordering."
    },
    "/webhooks/{webhookId}": {
      "schema": "object",
      "description": "Library of reusable external automation endpoints."
    }
  }
}
