{
  "entities": {
    "School": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "School",
      "type": "object",
      "description": "Represents a school using the SmartSApp onboarding platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the School entity."
        },
        "fullName": {
          "type": "string",
          "description": "The full name of the school."
        },
        "slogan": {
          "type": "string",
          "description": "The school's slogan or motto."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL of the school's logo.",
          "format": "uri"
        },
        "pageName": {
          "type": "string",
          "description": "The dynamically generated page name for the school (e.g., 'pe-ghana-international-school')."
        }
      },
      "required": [
        "id",
        "fullName",
        "slogan",
        "logoUrl",
        "pageName"
      ]
    },
    "MeetingPage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MeetingPage",
      "type": "object",
      "description": "Represents a dynamically generated meeting page for a specific school.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the MeetingPage entity."
        },
        "schoolId": {
          "type": "string",
          "description": "Reference to School. (Relationship: School 1:N MeetingPage)"
        },
        "meetingTime": {
          "type": "string",
          "description": "The date and time of the meeting.",
          "format": "date-time"
        },
        "meetingLink": {
          "type": "string",
          "description": "URL for joining the meeting.",
          "format": "uri"
        },
        "heroImage": {
          "type": "string",
          "description": "URL of the hero image for the meeting page.",
          "format": "uri"
        },
        "heroText": {
          "type": "string",
          "description": "Main text displayed in the hero section."
        },
        "heroDescription": {
          "type": "string",
          "description": "Descriptive text accompanying the hero text."
        },
        "videoCaption": {
          "type": "string",
          "description": "Caption for the video section."
        },
        "videoDescription": {
          "type": "string",
          "description": "Description accompanying the video section."
        }
      },
      "required": [
        "id",
        "schoolId",
        "meetingTime",
        "meetingLink",
        "heroImage",
        "heroText",
        "heroDescription",
        "videoCaption",
        "videoDescription"
      ]
    },
    "DownloadLink": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DownloadLink",
      "type": "object",
      "description": "Represents a download link for the SmartSApp mobile app on a specific platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the DownloadLink entity."
        },
        "meetingPageId": {
          "type": "string",
          "description": "Reference to MeetingPage. (Relationship: MeetingPage 1:N DownloadLink)"
        },
        "platform": {
          "type": "string",
          "description": "The platform for which the download link is provided (e.g., Android, iOS, Huawei)."
        },
        "url": {
          "type": "string",
          "description": "The URL for downloading the app on the specified platform.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "meetingPageId",
        "platform",
        "url"
      ]
    },
    "HelpVideo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HelpVideo",
      "type": "object",
      "description": "Represents a helpful video resource for users.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the HelpVideo entity."
        },
        "meetingPageId": {
          "type": "string",
          "description": "Reference to MeetingPage. (Relationship: MeetingPage 1:N HelpVideo)"
        },
        "title": {
          "type": "string",
          "description": "The title of the help video."
        },
        "url": {
          "type": "string",
          "description": "The URL of the help video (e.g., YouTube link).",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "meetingPageId",
        "title",
        "url"
      ]
    },
    "Testimonial": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Testimonial",
      "type": "object",
      "description": "Represents a video testimonial from a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Testimonial entity."
        },
        "meetingPageId": {
          "type": "string",
          "description": "Reference to MeetingPage. (Relationship: MeetingPage 1:N Testimonial)"
        },
        "name": {
          "type": "string",
          "description": "The name of the person giving the testimonial."
        },
        "title": {
          "type": "string",
          "description": "Title or role of the person giving the testimonial."
        },
        "videoUrl": {
          "type": "string",
          "description": "The URL of the testimonial video.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "meetingPageId",
        "name",
        "title",
        "videoUrl"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/schools/{schoolId}",
        "definition": {
          "entityName": "School",
          "schema": {
            "$ref": "#/backend/entities/School"
          },
          "description": "Stores school data. Each document represents a school using the SmartSApp onboarding platform."
        }
      },
      {
        "path": "/schools/{schoolId}/meetingPages/{meetingPageId}",
        "definition": {
          "entityName": "MeetingPage",
          "schema": {
            "$ref": "#/backend/entities/MeetingPage"
          },
          "description": "Stores dynamically generated meeting pages for each school. Each document represents a specific meeting page associated with a school."
        }
      },
      {
        "path": "/schools/{schoolId}/meetingPages/{meetingPageId}/downloadLinks/{downloadLinkId}",
        "definition": {
          "entityName": "DownloadLink",
          "schema": {
            "$ref": "#/backend/entities/DownloadLink"
          },
          "description": "Stores download links for the SmartSApp mobile app for specific meeting pages."
        }
      },
      {
        "path": "/schools/{schoolId}/meetingPages/{meetingPageId}/helpVideos/{helpVideoId}",
        "definition": {
          "entityName": "HelpVideo",
          "schema": {
            "$ref": "#/backend/entities/HelpVideo"
          },
          "description": "Stores helpful video resources for users associated with a specific meeting page."
        }
      },
      {
        "path": "/schools/{schoolId}/meetingPages/{meetingPageId}/testimonials/{testimonialId}",
        "definition": {
          "entityName": "Testimonial",
          "schema": {
            "$ref": "#/backend/entities/Testimonial"
          },
          "description": "Stores video testimonials from users associated with a specific meeting page."
        }
      }
    ]
  }
}
