
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Administrative user data and authorization status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "color": { "type": "string" },
        "isAuthorized": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Zone": {
      "title": "Zone",
      "description": "Geographic or organizational area for grouping schools.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "FocalPerson": {
      "title": "Focal Person",
      "description": "Contact person within a school with a specific role.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string", "enum": ["Champion", "Accountant", "Administrator", "Principal", "School Owner"] }
      }
    },
    "School": {
      "title": "School",
      "description": "Details about an onboarding school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "location": { "type": "string" },
        "nominalRoll": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Archived"] },
        "zone": { "$ref": "#/entities/Zone" },
        "focalPersons": { "type": "array", "items": { "$ref": "#/entities/FocalPerson" } },
        "stage": { "type": "object" },
        "assignedTo": { "type": "object" },
        "modules": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Meeting": {
      "title": "Meeting",
      "description": "Onboarding session or parent engagement meeting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "schoolSlug": { "type": "string" },
        "meetingTime": { "type": "string", "format": "date-time" },
        "meetingLink": { "type": "string" },
        "type": { "type": "object" },
        "recordingUrl": { "type": "string" },
        "brochureUrl": { "type": "string" }
      }
    },
    "Survey": {
      "title": "Survey",
      "description": "Intelligent, scored feedback form.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "elements": { "type": "array" },
        "scoringEnabled": { "type": "boolean" },
        "maxScore": { "type": "number" },
        "videoUrl": { "type": "string" },
        "videoThumbnailUrl": { "type": "string" }
      }
    },
    "PDFForm": {
      "title": "PDF Form",
      "description": "Interactive document mapping for digital signing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "publicTitle": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "fields": { "type": "array" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "Logged event in the activity timeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "schoolSlug": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "source": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "Administrative CRM task assigned to a team member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "cancelled"] },
        "category": { "type": "string", "enum": ["call", "visit", "document", "training", "general"] },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "assignedTo": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "enum": ["manual", "automation", "system"] }
      }
    },
    "AutomationRule": {
      "title": "Automation Rule",
      "description": "System-wide rule for triggering automated actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "isActive": { "type": "boolean" },
        "actions": { "type": "array" }
      }
    },
    "SurveySession": {
      "title": "Survey Session",
      "description": "Tracking record for an individual survey participant's progress.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "surveyId": { "type": "string" },
        "maxStepReached": { "type": "number" },
        "isSubmitted": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "PdfSession": {
      "title": "PDF Session",
      "description": "Tracking record for an individual PDF signer's scroll progress and completion.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pdfId": { "type": "string" },
        "maxPageReached": { "type": "number" },
        "isSubmitted": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CampaignSession": {
      "title": "Campaign Session",
      "description": "Analytics tracking for marketing campaign pages.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "campaignId": { "type": "string" },
        "selectedOption": { "type": "string", "enum": ["school", "parent"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles managed by admins."
    },
    "/zones/{zoneId}": {
      "schema": "#/entities/Zone",
      "description": "Organizational geographic zones."
    },
    "/schools/{schoolId}": {
      "schema": "#/entities/School",
      "description": "Schools in the onboarding pipeline."
    },
    "/meetings/{meetingId}": {
      "schema": "#/entities/Meeting",
      "description": "Meeting records."
    },
    "/surveys/{surveyId}": {
      "schema": "#/entities/Survey",
      "description": "Survey definitions."
    },
    "/pdfs/{pdfId}": {
      "schema": "#/entities/PDFForm",
      "description": "Doc signing templates."
    },
    "/activities/{activityId}": {
      "schema": "#/entities/Activity",
      "description": "Audit logs and interaction notes."
    },
    "/tasks/{taskId}": {
      "schema": "#/entities/Task",
      "description": "CRM task registry."
    },
    "/automations/{ruleId}": {
      "schema": "#/entities/AutomationRule",
      "description": "Global trigger hub rules."
    },
    "/survey_sessions/{sessionId}": {
      "schema": "#/entities/SurveySession",
      "description": "Ephemeral tracking of survey progress."
    },
    "/pdf_sessions/{sessionId}": {
      "schema": "#/entities/PdfSession",
      "description": "Ephemeral tracking of PDF document engagement."
    },
    "/campaign_sessions/{sessionId}": {
      "schema": "#/entities/CampaignSession",
      "description": "Real-time engagement metrics for marketing pages."
    }
  }
}
