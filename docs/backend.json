{
  "entities": {
    "School": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "School",
      "type": "object",
      "description": "Represents a school using the SmartSApp onboarding platform.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The full name of the school."
        },
        "slug": {
          "type": "string",
          "description": "The dynamically generated page name for the school (e.g., 'ghana-international-school')."
        },
        "slogan": {
          "type": "string",
          "description": "The school's slogan or motto."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL of the school's logo.",
          "format": "uri"
        },
        "heroImageUrl": {
          "type": "string",
          "description": "URL of the hero image for the meeting page.",
          "format": "uri"
        },
        "contactPerson": {
          "type": "string",
          "description": "Admin contact for the school."
        },
        "email": {
          "type": "string",
          "description": "School contact email.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "School contact phone."
        },
        "location": {
          "type": "string",
          "description": "City / Region of the school."
        },
        "nominalRoll": {
          "type": "number",
          "description": "Student population size."
        },
        "modules": {
          "type": "string",
          "description": "Modules being onboarded."
        },
        "implementationDate": {
          "type": "string",
          "description": "Go-live date.",
          "format": "date-time"
        },
        "referee": {
          "type": "string",
          "description": "Who introduced the school."
        },
        "includeDroneFootage": {
          "type": "boolean",
          "description": "Whether to include drone footage."
        }
      },
      "required": [
        "name",
        "slug"
      ]
    },
    "Meeting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Meeting",
      "type": "object",
      "description": "Represents a scheduled meeting for a school.",
      "properties": {
        "schoolId": {
          "type": "string",
          "description": "The ID of the school this meeting is for."
        },
        "schoolName": {
          "type": "string",
          "description": "The name of the school this meeting is for."
        },
        "schoolSlug": {
          "type": "string",
          "description": "The slug of the school for generating the meeting page URL."
        },
        "meetingTime": {
          "type": "string",
          "description": "The date and time of the meeting.",
          "format": "date-time"
        },
        "meetingLink": {
          "type": "string",
          "description": "URL for joining the meeting.",
          "format": "uri"
        },
        "recordingUrl": {
          "type": "string",
          "description": "URL of the meeting recording (e.g., YouTube).",
          "format": "uri"
        }
      },
      "required": ["schoolId", "schoolName", "schoolSlug", "meetingTime", "meetingLink"]
    },
    "MediaAsset": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Media Asset",
      "type": "object",
      "description": "Represents a media file (image, video, audio, document) in the library.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The original filename of the media asset."
        },
        "url": {
          "type": "string",
          "description": "The public download URL from Firebase Storage.",
          "format": "uri"
        },
        "fullPath": {
          "type": "string",
          "description": "The full path to the file within Firebase Storage (e.g., 'media/image/file.png')."
        },
        "type": {
          "type": "string",
          "description": "The type of media asset.",
          "enum": ["image", "video", "audio", "document"]
        },
        "mimeType": {
          "type": "string",
          "description": "The MIME type of the file (e.g., 'image/png')."
        },
        "size": {
          "type": "number",
          "description": "The file size in bytes."
        },
        "uploadedBy": {
          "type": "string",
          "description": "The UID of the user who uploaded the asset."
        },
        "createdAt": {
          "type": "string",
          "description": "The ISO timestamp when the asset was uploaded.",
          "format": "date-time"
        }
      },
      "required": ["name", "url", "fullPath", "type", "mimeType", "size", "uploadedBy", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/schools/{schoolId}",
        "definition": {
          "entityName": "School",
          "schema": {
            "$ref": "#/backend/entities/School"
          },
          "description": "Stores school data. Each document represents a school using the SmartSApp onboarding platform."
        }
      },
       {
        "path": "/meetings/{meetingId}",
        "definition": {
          "entityName": "Meeting",
          "schema": {
            "$ref": "#/backend/entities/Meeting"
          },
          "description": "Stores meeting data for schools. Each document represents a specific meeting."
        }
      },
      {
        "path": "/media/{mediaId}",
        "definition": {
          "entityName": "MediaAsset",
          "schema": {
            "$ref": "#/backend/entities/MediaAsset"
          },
          "description": "Stores all media assets uploaded to the application."
        }
      }
    ]
  }
}
