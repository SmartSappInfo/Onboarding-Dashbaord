{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Administrative user data and authorization status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "color": { "type": "string" },
        "isAuthorized": { "type": "boolean" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Automation": {
      "title": "Automation Blueprint",
      "description": "Definition of a node-based logic workflow.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "trigger": { "type": "string", "enum": ["SCHOOL_CREATED", "SCHOOL_STAGE_CHANGED", "TASK_COMPLETED", "SURVEY_SUBMITTED", "PDF_SIGNED"] },
        "nodes": { "type": "array" },
        "edges": { "type": "array" },
        "isActive": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AutomationRun": {
      "title": "Automation Execution",
      "description": "Trace of an automation run.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "automationId": { "type": "string" },
        "automationName": { "type": "string" },
        "triggerData": { "type": "object" },
        "status": { "type": "string", "enum": ["running", "completed", "failed"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "error": { "type": "string" }
      }
    },
    "Pipeline": {
      "title": "Pipeline",
      "description": "Definition of an operational workflow with a sequence of stages.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "stageIds": { "type": "array", "items": { "type": "string" } },
        "accessRoles": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SubscriptionPackage": {
      "title": "Subscription Package",
      "description": "Predefined pricing tiers for school subscriptions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ratePerStudent": { "type": "number" },
        "billingTerm": { "type": "string", "enum": ["term", "semester", "year"] },
        "currency": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "BillingPeriod": {
      "title": "Billing Period",
      "description": "Definition of a specific invoicing cycle.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "invoiceDate": { "type": "string", "format": "date-time" },
        "paymentDueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      }
    },
    "InvoiceItem": {
      "title": "Invoice Item",
      "description": "A single line item on an invoice.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "amount": { "type": "number" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A financial record for a school for a specific billing period.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "periodId": { "type": "string" },
        "periodName": { "type": "string" },
        "nominalRoll": { "type": "number" },
        "packageId": { "type": "string" },
        "packageName": { "type": "string" },
        "ratePerStudent": { "type": "number" },
        "currency": { "type": "string" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "levyAmount": { "type": "number" },
        "vatAmount": { "type": "number" },
        "arrearsAdded": { "type": "number" },
        "creditDeducted": { "type": "number" },
        "totalPayable": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "partial", "overdue"] },
        "items": { "type": "array", "items": { "$ref": "#/entities/InvoiceItem" } },
        "paymentInstructions": { "type": "string" },
        "signatureName": { "type": "string" },
        "signatureDesignation": { "type": "string" },
        "signatureUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "sentAt": { "type": "string", "format": "date-time" }
      }
    },
    "BillingSettings": {
      "title": "Billing Settings",
      "description": "Global configuration for the invoicing engine.",
      "type": "object",
      "properties": {
        "levyPercent": { "type": "number" },
        "vatPercent": { "type": "number" },
        "defaultDiscount": { "type": "number" },
        "paymentInstructions": { "type": "string" },
        "signatureName": { "type": "string" },
        "signatureDesignation": { "type": "string" },
        "signatureUrl": { "type": "string" }
      }
    },
    "Zone": {
      "title": "Zone",
      "description": "Geographic or organizational area for grouping schools.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "FocalPerson": {
      "title": "Focal Person",
      "description": "Contact person within a school with a specific role.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string" },
        "isSignatory": { "type": "boolean" },
        "isBillingOfficer": { "type": "boolean" },
        "isContractSignatory": { "type": "boolean" }
      }
    },
    "School": {
      "title": "School",
      "description": "Details about an onboarding school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "location": { "type": "string" },
        "billingAddress": { "type": "string" },
        "currency": { "type": "string" },
        "subscriptionPackageId": { "type": "string" },
        "subscriptionRate": { "type": "number" },
        "billingTerm": { "type": "string" },
        "nominalRoll": { "type": "number" },
        "arrearsBalance": { "type": "number" },
        "creditBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Archived"] },
        "lifecycleStatus": { "type": "string", "enum": ["Onboarding", "Active", "Churned"] },
        "pipelineId": { "type": "string" },
        "zone": { "$ref": "#/entities/Zone" },
        "focalPersons": { "type": "array", "items": { "$ref": "#/entities/FocalPerson" } },
        "stage": { "type": "object" },
        "assignedTo": { "type": "object" },
        "modules": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Contract": {
      "title": "Contract",
      "description": "A legal agreement between SmartSapp and a school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "pdfId": { "type": "string" },
        "status": { "type": "string", "enum": ["no_contract", "draft", "sent", "signed"] },
        "submissionId": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "signedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Meeting": {
      "title": "Meeting",
      "description": "Onboarding session or parent engagement meeting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "schoolSlug": { "type": "string" },
        "meetingTime": { "type": "string", "format": "date-time" },
        "meetingLink": { "type": "string" },
        "type": { "type": "object" },
        "recordingUrl": { "type": "string" },
        "brochureUrl": { "type": "string" }
      }
    },
    "Survey": {
      "title": "Survey",
      "description": "Intelligent, scored feedback form.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "elements": { "type": "array" },
        "scoringEnabled": { "type": "boolean" },
        "maxScore": { "type": "number" },
        "videoUrl": { "type": "string" },
        "videoThumbnailUrl": { "type": "string" },
        "videoCaption": { "type": "string" }
      }
    },
    "PDFForm": {
      "title": "PDF Form",
      "description": "Interactive document mapping for digital signing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "publicTitle": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "fields": { "type": "array" },
        "isContractDocument": { "type": "boolean" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "Logged event in the activity timeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "schoolSlug": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "source": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "Administrative CRM task assigned to a team member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "cancelled"] },
        "category": { "type": "string", "enum": ["call", "visit", "document", "training", "general"] },
        "schoolId": { "type": "string" },
        "schoolName": { "type": "string" },
        "assignedTo": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "enum": ["manual", "automation", "system"] }
      }
    },
    "AutomationRule": {
      "title": "Automation Rule",
      "description": "System-wide rule for triggering automated actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "isActive": { "type": "boolean" },
        "actions": { "type": "array" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles managed by admins."
    },
    "/pipelines/{pipelineId}": {
      "schema": "#/entities/Pipeline",
      "description": "Operational workflow definitions."
    },
    "/zones/{zoneId}": {
      "schema": "#/entities/Zone",
      "description": "Organizational geographic zones."
    },
    "/schools/{schoolId}": {
      "schema": "#/entities/School",
      "description": "Schools in the onboarding pipeline."
    },
    "/meetings/{meetingId}": {
      "schema": "#/entities/Meeting",
      "description": "Meeting records."
    },
    "/surveys/{surveyId}": {
      "schema": "#/entities/Survey",
      "description": "Survey definitions."
    },
    "/pdfs/{pdfId}": {
      "schema": "#/entities/PDFForm",
      "description": "Doc signing templates."
    },
    "/contracts/{contractId}": {
      "schema": "#/entities/Contract",
      "description": "Institutional agreement records."
    },
    "/activities/{activityId}": {
      "schema": "#/entities/Activity",
      "description": "Audit logs and interaction notes."
    },
    "/tasks/{taskId}": {
      "schema": "#/entities/Task",
      "description": "CRM task registry."
    },
    "/automations/{ruleId}": {
      "schema": "#/entities/Automation",
      "description": "Automation blueprints."
    },
    "/automation_runs/{runId}": {
      "schema": "#/entities/AutomationRun",
      "description": "Trace ledger for automated executions."
    }
  }
}
