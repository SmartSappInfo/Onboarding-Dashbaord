
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Administrative user data and authorization status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "color": { "type": "string" },
        "isAuthorized": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "School": {
      "title": "School",
      "description": "Details about an onboarding school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "location": { "type": "string" },
        "nominalRoll": { "type": "number" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "stage": { "type": "object" },
        "assignedTo": { "type": "object" },
        "modules": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Webhook": {
      "title": "Webhook",
      "description": "A reusable named external endpoint for data integration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "A friendly name for the webhook." },
        "url": { "type": "string", "format": "uri", "description": "The external endpoint URL." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "url"]
    },
    "Survey": {
      "title": "Survey",
      "description": "A feedback form or assessment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "webhookId": { "type": "string", "description": "Reference to a Webhook entity." },
        "webhookEnabled": { "type": "boolean", "description": "Whether to fire the webhook on submission." },
        "scoringEnabled": { "type": "boolean" },
        "maxScore": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles managed by admins."
    },
    "/schools/{schoolId}": {
      "schema": "#/entities/School",
      "description": "Schools in the onboarding pipeline."
    },
    "/webhooks/{webhookId}": {
      "schema": "#/entities/Webhook",
      "description": "Reusable webhook endpoints."
    },
    "/surveys/{surveyId}": {
      "schema": "#/entities/Survey",
      "description": "Configurable surveys and assessments."
    }
  }
}
