rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    match /{allPaths=**} {
      allow read;
    }

    // Restrict write access (uploads, updates, deletes) to authenticated users
    // specifically within the /media folder.
    match /media/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
