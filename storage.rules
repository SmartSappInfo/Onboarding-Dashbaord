
rules_version = '2';

// Triggering synchronization.

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files for simplicity.
    match /{allPaths=**} {
      allow read;
    }

    // Restrict write access (uploads, updates, deletes) to authenticated users.
    match /media/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // Allow users to write to their own profile picture path.
    match /profile-pictures/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow uploads to survey-uploads path for any authenticated user
    match /survey-uploads/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Allow admins to upload to the pdfs path
    match /pdfs/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
